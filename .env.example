# =============================================================
# telegram-local-ingest environment template
# Commit this file. Put real values only in .env.
# =============================================================

# -------------------------------------------------------------
# AI provider credentials for Codex/Claude/Gemini tooling
# Usually unnecessary when the local CLIs are already logged in.
# -------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -------------------------------------------------------------
# Telegram bot and Local Bot API Server
# BOT_TOKEN is from BotFather.
# API_ID/API_HASH are from https://my.telegram.org/apps and are
# required to run tdlib/telegram-bot-api locally.
# -------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_API_BASE_URL=http://127.0.0.1:8081
TELEGRAM_BOT_API_BIN=
TELEGRAM_BOT_API_HOST=127.0.0.1
TELEGRAM_BOT_API_PORT=8081
TELEGRAM_BOT_API_TEMP_DIR=
TELEGRAM_LOCAL_FILES_ROOT=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=50

# -------------------------------------------------------------
# Runtime storage
# Keep runtime outside the Obsidian vault. Only finalized raw
# bundles should be written into the vault.
# -------------------------------------------------------------
INGEST_RUNTIME_DIR=./runtime
INGEST_LOG_DIR=./runtime/logs
INGEST_PID_DIR=./runtime/pids
SQLITE_DB_PATH=./runtime/ingest.db
INGEST_MAX_FILE_SIZE_BYTES=2147483648
OBSIDIAN_VAULT_PATH=
OBSIDIAN_RAW_ROOT=raw

# -------------------------------------------------------------
# Worker concurrency
# Polling stays responsive while a small worker pool processes jobs.
# Keep agent concurrency at 1 for personal OAuth CLI stability.
# Expired runtime outputs are cleaned on startup and then on this cadence.
# -------------------------------------------------------------
WORKER_JOB_CONCURRENCY=2
WORKER_STT_CONCURRENCY=1
WORKER_AGENT_CONCURRENCY=1
WORKER_JOB_CLAIM_TTL_MS=7200000
WORKER_OUTPUT_CLEANUP_INTERVAL_MS=600000

# -------------------------------------------------------------
# STT provider
# Use rtzr for cloud RTZR, sensevoice for on-demand local CPU SenseVoice,
# or none to skip audio/voice transcription.
# -------------------------------------------------------------
STT_PROVIDER=rtzr

# -------------------------------------------------------------
# RTZR STT
# -------------------------------------------------------------
RTZR_CLIENT_ID=
RTZR_CLIENT_SECRET=
RTZR_API_BASE_URL=https://openapi.vito.ai
FFMPEG_PATH=ffmpeg
RTZR_POLL_INTERVAL_MS=5000
RTZR_TIMEOUT_MS=1800000
RTZR_RATE_LIMIT_BACKOFF_MS=30000

# -------------------------------------------------------------
# SenseVoice local CPU STT
# Run npm run setup:linux:sensevoice once. It installs system dependencies,
# creates .venv-sensevoice, and prewarms the model cache so the first live
# job does not block on SenseVoice model download.
# -------------------------------------------------------------
SENSEVOICE_PYTHON=python3
SENSEVOICE_SCRIPT_PATH=./scripts/sensevoice-transcribe.py
SENSEVOICE_MODEL=iic/SenseVoiceSmall
SENSEVOICE_VAD_MODEL=fsmn-vad
SENSEVOICE_DEVICE=cpu
SENSEVOICE_LANGUAGE=auto
SENSEVOICE_USE_ITN=true
SENSEVOICE_BATCH_SIZE_SECONDS=60
SENSEVOICE_MERGE_VAD=true
SENSEVOICE_MERGE_LENGTH_SECONDS=15
SENSEVOICE_MAX_SINGLE_SEGMENT_TIME_MS=30000
SENSEVOICE_TIMEOUT_MS=3600000
SENSEVOICE_TORCH_NUM_THREADS=

# -------------------------------------------------------------
# LLM wiki ingest and chat adapters
# This is intentionally a command boundary. Raw bundles remain
# immutable; adapters are allowed to update wiki notes only.
# -------------------------------------------------------------
WIKI_INGEST_COMMAND=
WIKI_CHAT_COMMAND=
WIKI_CHAT_TIMEOUT_MS=300000
# Optional override for the internal text-only wiki chat agent.
# If unset, yoni-llm-wiki/scripts/chat.mjs uses Claude CLI in read-only mode.
WIKI_CHAT_AGENT_COMMAND=
WIKI_CHAT_AGENT_TIMEOUT_MS=270000
WIKI_CHAT_CLAUDE_ALLOWED_TOOLS=Read,Glob,Grep
WIKI_CHAT_CLAUDE_PERMISSION_MODE=acceptEdits
WIKI_WRITE_LOCK_PATH=./runtime/wiki.lock

# Derived artifact renderers. Registered renderers live under the wiki vault
# by default; generated renderer runs are logged under runtime for dashboard
# review and optional promotion.
WIKI_RENDERERS_DIR=renderers
WIKI_DERIVED_INGEST_COMMAND=
WIKI_ARTIFACT_ALLOW_GENERATED_RENDERERS=true
WIKI_ARTIFACT_RUNS_DIR=./runtime/wiki-artifacts/runs
# Python used for registered/generated Python artifact renderers.
# `npm run setup:wiki-artifacts` creates ./.venv-wiki-artifacts with matplotlib.
WIKI_ARTIFACT_PYTHON_BIN=

# -------------------------------------------------------------
# Product automation modules
# Keep package.json stable by registering one-shot modules under automations/*.
# The ops CLI discovers these manifests and writes run logs under runtime.
# -------------------------------------------------------------
AUTOMATION_MODULES_DIR=./automations
AUTOMATION_RUNS_DIR=./runtime/automation/runs

# Localhost-only automation dashboard. The token protects write actions only
# (enable/disable/manual run/dispatch); read-only status pages remain local GETs.
# Leave it empty for personal loopback-only use.
OPS_DASHBOARD_HOST=127.0.0.1
OPS_DASHBOARD_PORT=58991
OPS_DASHBOARD_TOKEN=

# Korea Eximbank daily FX automation
FX_KOREAEXIM_AUTHKEY=
FX_KOREAEXIM_API_BASE_URL=https://oapi.koreaexim.go.kr/site/program/financial/exchangeJSON
FX_CURRENCIES="USD,JPY(100),EUR,CNH"
FX_SEARCH_DATE=
FX_KOREAEXIM_FIXTURE_PATH=
FX_SKIP_EMPTY_BUNDLE=

# -------------------------------------------------------------
# Future translation/post-processing context
# -------------------------------------------------------------
TRANSLATION_DEFAULT_RELATION=business
TRANSLATION_TARGET_LANGUAGE=ko

# -------------------------------------------------------------
# Local agent post-processing
# Keep disabled until the command is reviewed for your local CLI.
# Supported providers: none, codex, claude, custom.
# AGENT_POSTPROCESS_COMMAND may use placeholders:
# {projectRoot} {promptFile} {outputDir} {bundlePath} {jobId}
# If {promptFile} is omitted, the prompt is sent on stdin.
# Codex example:
# AGENT_POSTPROCESS_COMMAND='{projectRoot}/scripts/run-codex-postprocess.sh --prompt {promptFile} --output {outputDir} --bundle {bundlePath} --job {jobId}'
# Optional Codex CLI wrapper tuning: CODEX_MODEL, CODEX_SANDBOX, CODEX_RETRY.
# Claude example:
# AGENT_POSTPROCESS_PROVIDER=claude
# AGENT_POSTPROCESS_COMMAND='{projectRoot}/scripts/run-claude-postprocess.sh --prompt {promptFile} --output {outputDir} --bundle {bundlePath} --job {jobId}'
# Optional Claude CLI wrapper tuning: CLAUDE_BIN, CLAUDE_MODEL, CLAUDE_PERMISSION_MODE, CLAUDE_ALLOWED_TOOLS, CLAUDE_MAX_BUDGET_USD.
# Optional PDF font override for Korean/CJK mobile downloads for non-document sources.
# npm run setup:linux installs fonts-noto-cjk and fills this with the detected
# Noto CJK font path when the value is empty.
# Optional document processing tools. pandoc renders DOCX deliverables when the
# agent returns Markdown. pdftotext extracts text from PDF uploads, while
# pdftoppm renders PDF original pages into DOCX image snapshots and combines
# with tesseract for OCR fallback on scanned PDFs and image uploads.
# PANDOC_REFERENCE_DOCX is optional and lets derived/report DOCX renders inherit
# a custom Word style template.
# -------------------------------------------------------------
AGENT_POSTPROCESS_PROVIDER=none
AGENT_POSTPROCESS_COMMAND=
AGENT_POSTPROCESS_TIMEOUT_MS=1800000
PDF_FONT_PATH=
PANDOC_BIN=
PANDOC_REFERENCE_DOCX=
PDFTOTEXT_BIN=
PDFTOPPM_BIN=
TESSERACT_BIN=
OCR_LANGUAGES=kor+eng+chi_sim+jpn
OCR_PSM=3
PDF_OCR_MAX_PAGES=10
PDF_OCR_DPI=200
PDF_ORIGINAL_RENDER_DPI=150
PDF_ORIGINAL_MAX_PAGES=
