# =============================================================
# telegram-local-ingest environment template
# Commit this file. Put real values only in .env.
# =============================================================

# -------------------------------------------------------------
# AI provider credentials for Codex/Claude/Gemini tooling
# Usually unnecessary when the local CLIs are already logged in.
# -------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -------------------------------------------------------------
# Telegram bot and Local Bot API Server
# BOT_TOKEN is from BotFather.
# API_ID/API_HASH are from https://my.telegram.org/apps and are
# required to run tdlib/telegram-bot-api locally.
# -------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_API_BASE_URL=http://127.0.0.1:8081
TELEGRAM_LOCAL_FILES_ROOT=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=50

# -------------------------------------------------------------
# Runtime storage
# Keep runtime outside the Obsidian vault. Only finalized raw
# bundles should be written into the vault.
# -------------------------------------------------------------
INGEST_RUNTIME_DIR=./runtime
SQLITE_DB_PATH=./runtime/ingest.db
INGEST_MAX_FILE_SIZE_BYTES=2147483648
OBSIDIAN_VAULT_PATH=
OBSIDIAN_RAW_ROOT=raw

# -------------------------------------------------------------
# RTZR STT
# -------------------------------------------------------------
RTZR_CLIENT_ID=
RTZR_CLIENT_SECRET=
RTZR_API_BASE_URL=https://openapi.vito.ai
FFMPEG_PATH=ffmpeg

# -------------------------------------------------------------
# LLM wiki ingest adapter
# This is intentionally a command boundary. Raw bundles remain
# immutable; the adapter is allowed to update wiki notes only.
# -------------------------------------------------------------
WIKI_INGEST_COMMAND=
WIKI_WRITE_LOCK_PATH=./runtime/wiki.lock
