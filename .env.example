# =============================================================
# telegram-local-ingest environment template
# Commit this file. Put real values only in .env.
# =============================================================

# -------------------------------------------------------------
# AI provider credentials for Codex/Claude/Gemini tooling
# Usually unnecessary when the local CLIs are already logged in.
# -------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -------------------------------------------------------------
# Telegram bot and Local Bot API Server
# BOT_TOKEN is from BotFather.
# API_ID/API_HASH are from https://my.telegram.org/apps and are
# required to run tdlib/telegram-bot-api locally.
# -------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_API_BASE_URL=http://127.0.0.1:8081
TELEGRAM_BOT_API_BIN=/home/tony/.local/bin/telegram-bot-api
TELEGRAM_BOT_API_HOST=127.0.0.1
TELEGRAM_BOT_API_PORT=8081
TELEGRAM_BOT_API_TEMP_DIR=/home/tony/telegram-bot-api-temp
TELEGRAM_LOCAL_FILES_ROOT=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=50

# -------------------------------------------------------------
# Runtime storage
# Keep runtime outside the Obsidian vault. Only finalized raw
# bundles should be written into the vault.
# -------------------------------------------------------------
INGEST_RUNTIME_DIR=./runtime
INGEST_LOG_DIR=./runtime/logs
INGEST_PID_DIR=./runtime/pids
SQLITE_DB_PATH=./runtime/ingest.db
INGEST_MAX_FILE_SIZE_BYTES=2147483648
OBSIDIAN_VAULT_PATH=
OBSIDIAN_RAW_ROOT=raw

# -------------------------------------------------------------
# STT provider
# Use rtzr for cloud RTZR, sensevoice for on-demand local CPU SenseVoice,
# or none to skip audio/voice transcription.
# -------------------------------------------------------------
STT_PROVIDER=rtzr

# -------------------------------------------------------------
# RTZR STT
# -------------------------------------------------------------
RTZR_CLIENT_ID=
RTZR_CLIENT_SECRET=
RTZR_API_BASE_URL=https://openapi.vito.ai
FFMPEG_PATH=ffmpeg
RTZR_POLL_INTERVAL_MS=5000
RTZR_TIMEOUT_MS=1800000
RTZR_RATE_LIMIT_BACKOFF_MS=30000

# -------------------------------------------------------------
# SenseVoice local CPU STT
# Run scripts/setup-sensevoice-cpu.sh once. It installs dependencies
# and prewarms the model cache so the first live job does not block
# on SenseVoice model download.
# -------------------------------------------------------------
SENSEVOICE_PYTHON=python3
SENSEVOICE_SCRIPT_PATH=./scripts/sensevoice-transcribe.py
SENSEVOICE_MODEL=iic/SenseVoiceSmall
SENSEVOICE_VAD_MODEL=fsmn-vad
SENSEVOICE_DEVICE=cpu
SENSEVOICE_LANGUAGE=auto
SENSEVOICE_USE_ITN=true
SENSEVOICE_BATCH_SIZE_SECONDS=60
SENSEVOICE_MERGE_VAD=true
SENSEVOICE_MERGE_LENGTH_SECONDS=15
SENSEVOICE_MAX_SINGLE_SEGMENT_TIME_MS=30000
SENSEVOICE_TIMEOUT_MS=3600000
SENSEVOICE_TORCH_NUM_THREADS=

# -------------------------------------------------------------
# LLM wiki ingest adapter
# This is intentionally a command boundary. Raw bundles remain
# immutable; the adapter is allowed to update wiki notes only.
# -------------------------------------------------------------
WIKI_INGEST_COMMAND=
WIKI_WRITE_LOCK_PATH=./runtime/wiki.lock

# -------------------------------------------------------------
# Future translation/post-processing context
# -------------------------------------------------------------
TRANSLATION_DEFAULT_RELATION=business
TRANSLATION_TARGET_LANGUAGE=ko
