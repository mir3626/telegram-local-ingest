{
  "name": "telegram-local-ingest",
  "version": "0.1.0",
  "harnessVersion": "1.5.2",
  "private": true,
  "type": "module",
  "description": "Telegram Local Bot API Server based local ingest worker for Obsidian LLM wiki raw bundles.",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.app.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.app.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "smoke:ready": "npx tsx apps/worker/src/readiness.ts",
    "smoke:agent:ready": "bash scripts/smoke-agent-postprocess.sh --ready",
    "smoke:agent:live": "bash scripts/smoke-agent-postprocess.sh --live",
    "setup:docx-rendering": "bash scripts/setup-docx-template-rendering.sh",
    "ops:start": "bash scripts/start-local-stack.sh",
    "ops:stop": "bash scripts/stop-local-stack.sh",
    "ops:restart": "bash scripts/restart-local-stack.sh",
    "worker:dev": "npm --workspace @telegram-local-ingest/worker run dev",
    "worker:start": "npm --workspace @telegram-local-ingest/worker run start",
    "vibe:doctor": "npx tsx src/commands/doctor.ts",
    "vibe:init": "npx tsx src/commands/init.ts",
    "vibe:interview": "node scripts/vibe-interview.mjs",
    "vibe:bundle-size": "npx tsx src/commands/bundle-size.ts",
    "vibe:browser-smoke": "node scripts/vibe-browser-smoke.mjs",
    "vibe:qa": "npx tsx src/commands/qa.ts",
    "vibe:usage": "npx tsx src/commands/summarize-usage.ts",
    "vibe:report": "npx tsx src/commands/write-report.ts",
    "vibe:config-audit": "npx tsx src/commands/audit-config.ts",
    "vibe:run-agent": "npx tsx src/commands/run-agent.ts",
    "vibe:sync": "npx tsx src/commands/sync.ts",
    "vibe:gen-schemas": "node scripts/vibe-gen-schemas.mjs",
    "vibe:audit-lightweight": "node scripts/vibe-audit-lightweight.mjs",
    "vibe:rule-audit": "node scripts/vibe-rule-audit.mjs",
    "vibe:dashboard": "node scripts/vibe-dashboard.mjs",
    "vibe:session-start": "node scripts/vibe-agent-session-start.mjs",
    "vibe:checkpoint": "node scripts/vibe-checkpoint.mjs"
  },
  "dependencies": {
    "pdfkit": "^0.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "zod-to-json-schema": "^3.23.0"
  }
}
